VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME="App Template"

# Supabase
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Standard OpenAI (Takes precedence if configured)
VITE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY
VITE_OPENAI_DEFAULT_MODEL=gpt-4o

# Azure OpenAI (Fallback if Standard not set)
VITE_AZURE_OPENAI_ENDPOINT=YOUR_AZURE_ENDPOINT
VITE_AZURE_OPENAI_API_KEY=YOUR_AZURE_API_KEY
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4.1
VITE_AZURE_OPENAI_DEPLOYMENT_VERSION="2025-01-01-preview"
